  "scripts": {
    "dev": "node -e \"const fs=require('fs');const orig=fs.realpathSync;fs.realpathSync=function(p,o){try{return orig.call(this,p,o)}catch(e){if(e&&e.code==='EPERM')return p;throw e}};fs.realpathSync.native=fs.realpathSync;process.argv=['node','next','dev'];require('./node_modules/next/dist/bin/next')\"",
    "build": "node -e \"const fs=require('fs');const orig=fs.realpathSync;fs.realpathSync=function(p,o){try{return orig.call(this,p,o)}catch(e){if(e&&e.code==='EPERM')return p;throw e}};fs.realpathSync.native=fs.realpathSync;process.argv=['node','next','build'];require('./node_modules/next/dist/bin/next')\"",
    "start": "node -e \"const fs=require('fs');const orig=fs.realpathSync;fs.realpathSync=function(p,o){try{return orig.call(this,p,o)}catch(e){if(e&&e.code==='EPERM')return p;throw e}};fs.realpathSync.native=fs.realpathSync;process.argv=['node','next','start'];require('./node_modules/next/dist/bin/next')\"",
    "typecheck": "node -e \"const fs=require('fs');const orig=fs.realpathSync;fs.realpathSync=function(p,o){try{return orig.call(this,p,o)}catch(e){if(e&&e.code==='EPERM')return p;throw e}};fs.realpathSync.native=fs.realpathSync;process.argv=['node','tsc','--noEmit'];require('./node_modules/typescript/lib/tsc.js')\""
  },
